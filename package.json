{
  "name": "iba-purdue",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "emulator": "firebase emulators:start --only auth,firestore",
    "emulator:export": "firebase emulators:start --only auth,firestore --export-on-exit=./emulator-data",
    "serve": "npx http-server . -p 8000 -c-1 --silent"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "firebase-admin": "^12.0.0",
    "http-server": "^14.1.1"
  }
}
